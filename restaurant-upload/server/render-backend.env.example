NODE_ENV=production
STATE_BACKEND=supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SCHEMA=public
SUPABASE_STATE_TABLE=app_state

PASSWORD_RESET_EMAIL_PROVIDER=resend
PASSWORD_RESET_EMAIL_API_KEY=YOUR_RESEND_API_KEY
PASSWORD_RESET_EMAIL_FROM=My Testing Restaurant <no-reply@yourdomain.com>
PASSWORD_RESET_EMAIL_REPLY_TO=support@yourdomain.com
PASSWORD_RESET_EMAIL_SUBJECT=Your password reset code
PASSWORD_RESET_EMAIL_BRAND=My Testing Restaurant

RESTAURANT_DASHBOARD_TOKEN=SET_A_LONG_RANDOM_TOKEN
RESTAURANT_INVITE_CODE=OPTIONAL_INVITE_CODE
RESTAURANT_STAFF_EMAILS=owner@example.com,manager@example.com
